---
import { type CollectionEntry } from 'astro:content';
import I18nKey from '../../i18n/i18nKey';
import { useTranslations } from '../../i18n/translation';
import { buildLocaleUrl, detectLocale } from '../../utils/i18n';
import { getSlugFromId } from '../../utils/pages';

interface Props {
  prev?: CollectionEntry<'blog'>;
  next?: CollectionEntry<'blog'>;
}

const currentLocale = detectLocale(Astro.url.pathname);
const t = useTranslations(currentLocale);
const { prev, next } = Astro.props;
---

<nav id="post-nav">
  {prev && (
    <a class="post-nav-item post-nav-prev" href={buildLocaleUrl(currentLocale, `/blog/${getSlugFromId(prev.id)}`)}>
      <div class="nav-arrow">{t(I18nKey.previous)}</div>
      <span class="post-title">{prev.data.title}</span>
    </a>
  )}
  {next && (
    <a class="post-nav-item post-nav-next" href={buildLocaleUrl(currentLocale, `/blog/${getSlugFromId(next.id)}`)}>
      <div class="nav-arrow">{t(I18nKey.next)}</div>
      <span class="post-title">{next.data.title}</span>
    </a>
  )}
</nav>
