---
import { type CollectionEntry } from 'astro:content';

type ArticleData = CollectionEntry<'blog'>['data'] | CollectionEntry<'pages'>['data'];

interface Props {
  data: ArticleData;
}

const { archive, trigger, disclaimer } = (Astro.props as Props).data;
---

{archive && (
    <div class="statement-container archive">
        <strong class="title">
            <i class="icon"></i>
            Archived
        </strong>
        {archive}
    </div>
)}

{trigger && (
    <div class="statement-container trigger">
        <strong class="title">
            <i class="icon"></i>
            Trigger Warning
        </strong>
        {trigger}
    </div>
)}

{disclaimer && (
    <div class="statement-container disclaimer">
        <strong class="title">
            <i class="icon"></i>
            Disclaimer
        </strong>
        {disclaimer}
    </div>
)}
