---
import Base from "../../layouts/Base.astro";
import LinkCard from "./LinkCard.astro";
import FriendsGraph from "./FriendsGraph.astro";
import { linkCategories, links } from "../../data/links";
import friendsGraphData from "../../data/friends-graph.json";
import { buildLocaleUrl } from "../../utils/i18n";

interface Props {
  locale: string;
}

const { locale } = Astro.props;

const categoryLabels = {
  en: {
    blog: "Blog",
    friends: "Friends",
    tech: "Tech",
    other: "Other",
  },
  "zh-cn": {
    blog: "博客",
    friends: "朋友",
    tech: "技术",
    other: "其他",
  },
} as const;

const copy = {
  en: {
    title: "Links",
    heading: "Links",
    kicker: "Bookmarks",
    introLead: "A small collection of personal sites, friends' blogs, and quiet corners on the internet that I keep returning to.",
    introTail: "They may not update often, but each of them has offered me a little spark at some point.",
    filtersLabel: "Browse by category",
    exchangeLink: "Exchange links",
    applyTitle: "Want to exchange links?",
    applyBody: [
      "If you also keep a personal site with care over time, I would be glad to exchange links.",
      "Traffic matters less to me than people who keep making sincere records.",
    ],
    contact: "Contact me",
    empty: "No links in this category yet.",
  },
  "zh-cn": {
    title: "友邻",
    heading: "友邻",
    kicker: "Bookmarks",
    introLead: "这里收集了一些我喜欢的个人站点、朋友的博客，以及在互联网上偶然遇见但愿意反复拜访的小房间。",
    introTail: "这些链接不一定常更新，但它们都在某个时刻给过我灵感。",
    filtersLabel: "按类别浏览",
    exchangeLink: "交换友链",
    applyTitle: "想交换友链？",
    applyBody: [
      "如果你也有一个长期维护的个人站点，欢迎来交换链接。",
      "比起流量，我更喜欢认真记录的人。",
    ],
    contact: "联系我",
    empty: "这个分类下还没有友链。",
  },
} as const;

const pageCopy = copy[locale as keyof typeof copy] ?? copy.en;
const labels = categoryLabels[locale as keyof typeof categoryLabels] ?? categoryLabels.en;
const contactHref = buildLocaleUrl(locale, "/about/");
const defaultCategory = "blog";

const categoryCounts = Object.fromEntries(
  linkCategories.map((category) => [
    category,
    category === "friends"
      ? friendsGraphData.nodes.filter((node) => node.type === "friend").length
      : links.filter((link) => link.category === category).length,
  ]),
) as Record<(typeof linkCategories)[number], number>;

const categories = linkCategories.map((category) => ({
  key: category,
  label: labels[category],
  count: categoryCounts[category],
}));

const blogLinks = links.filter((link) => link.category === "blog");
const techLinks = links.filter((link) => link.category === "tech");
const otherLinks = links.filter((link) => link.category === "other");
---

<Base
  title={pageCopy.title}
  description={pageCopy.introLead}
  mainClass="links-page-main"
>
  <section class="links-page" data-links-page data-default-filter={defaultCategory}>
    <header class="links-hero">
      <p class="links-kicker">{pageCopy.kicker}</p>
      <h1>{pageCopy.heading}</h1>
      <div class="links-copy">
        <p>{pageCopy.introLead}</p>
        <p>{pageCopy.introTail}</p>
      </div>
      <div class="links-hero-actions">
        <a class="exchange-link" href="#exchange">{pageCopy.exchangeLink} <span aria-hidden="true">↗</span></a>
      </div>
    </header>

    <section class="links-filters" aria-label={pageCopy.filtersLabel}>
      <div class="filter-row">
        <div class="filter-pills" role="toolbar">
          {categories.map((category) => (
            <button
              type="button"
              class:list={["filter-pill", category.key === defaultCategory && "active"]}
              data-filter={category.key}
              aria-pressed={category.key === defaultCategory ? "true" : "false"}
            >
              <span class="filter-pill-label">{category.label}</span>
              <span class="filter-pill-count">{category.count}</span>
            </button>
          ))}
        </div>
        <a class="exchange-link exchange-link-subtle" href="#exchange">{pageCopy.exchangeLink} <span aria-hidden="true">↗</span></a>
      </div>
    </section>

    <section class="links-panels">
      <section class="links-list" data-category-panel="blog">
        {blogLinks.map((link) => (
          <LinkCard link={link} />
        ))}
        {blogLinks.length === 0 ? <p class="links-empty">{pageCopy.empty}</p> : null}
      </section>

      <FriendsGraph locale={locale} />

      <section class="links-list" data-category-panel="tech" hidden>
        {techLinks.map((link) => (
          <LinkCard link={link} />
        ))}
        {techLinks.length === 0 ? <p class="links-empty">{pageCopy.empty}</p> : null}
      </section>

      <section class="links-list" data-category-panel="other" hidden>
        {otherLinks.map((link) => (
          <LinkCard link={link} />
        ))}
        {otherLinks.length === 0 ? <p class="links-empty">{pageCopy.empty}</p> : null}
      </section>
    </section>

    <section class="links-apply" id="exchange">
      <div class="links-apply-copy">
        <h2>{pageCopy.applyTitle}</h2>
        <div class="links-apply-body">
          {pageCopy.applyBody.map((paragraph) => (
            <p>{paragraph}</p>
          ))}
        </div>
      </div>
      <a class="exchange-link" href={contactHref}>{pageCopy.contact} <span aria-hidden="true">↗</span></a>
    </section>
  </section>
</Base>

<script is:inline>
  const initLinksPageFilters = () => {
    const roots = document.querySelectorAll("[data-links-page]");

    roots.forEach((root) => {
      const buttons = Array.from(root.querySelectorAll("[data-filter]"));
      const panels = Array.from(root.querySelectorAll("[data-category-panel]"));
      const defaultFilter = root.dataset.defaultFilter || "blog";

      const updateFilter = (nextFilter) => {
        root.setAttribute("data-active-filter", nextFilter);

        buttons.forEach((button) => {
          const isActive = button.dataset.filter === nextFilter;
          button.classList.toggle("active", isActive);
          button.setAttribute("aria-pressed", String(isActive));
        });

        panels.forEach((panel) => {
          const isActive = panel.dataset.categoryPanel === nextFilter;
          panel.toggleAttribute("hidden", !isActive);
          panel.setAttribute("aria-hidden", String(!isActive));
        });
      };

      buttons.forEach((button) => {
        button.addEventListener("click", () => {
          updateFilter(button.dataset.filter || defaultFilter);
        });
      });

      updateFilter(defaultFilter);
    });
  };

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", initLinksPageFilters, { once: true });
  } else {
    initLinksPageFilters();
  }
</script>

<style>
  .links-page {
    display: grid;
    gap: 1.75rem;
  }

  .links-hero {
    position: relative;
    box-shadow: var(--edge-highlight), var(--shadow-glass);
    border: 1px solid var(--fg-muted-2);
    border-radius: calc(var(--rounded-corner) + 0.25rem);
    background: color-mix(in srgb, var(--glass-bg) 88%, transparent);
    padding: 1.5rem;
    overflow: hidden;
  }

  .links-hero::before {
    position: absolute;
    inset: auto auto 0 0;
    transform: translate(-15%, 30%);
    opacity: 0.35;
    background: radial-gradient(circle, color-mix(in srgb, var(--accent-color) 12%, transparent) 0%, transparent 70%);
    width: 16rem;
    height: 16rem;
    pointer-events: none;
    content: "";
  }

  .links-kicker {
    margin: 0 0 0.75rem;
    color: var(--fg-muted-4);
    font-size: var(--font-size-small);
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .links-hero h1 {
    margin: 0;
    font-family: var(--heading-font-family);
    font-size: clamp(2rem, 4vw, 3.2rem);
    line-height: 1;
  }

  .links-copy {
    position: relative;
    z-index: 1;
    max-width: 34rem;
  }

  .links-copy p {
    margin: 1rem 0 0;
    color: var(--fg-muted-5);
    font-size: 1.02rem;
  }

  .links-hero-actions {
    position: relative;
    z-index: 1;
    display: flex;
    justify-content: flex-end;
    margin-top: 1.25rem;
  }

  .exchange-link {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    transition: color var(--transition), background-color var(--transition), border-color var(--transition);
    border: 1px solid transparent;
    border-radius: 999px;
    padding: 0.375rem 0.625rem;
    color: var(--fg-muted-4);
    font-size: var(--font-size-small);
    line-height: 1;
    text-decoration: none;
  }

  .exchange-link:hover {
    border-color: color-mix(in srgb, var(--accent-color) 28%, var(--fg-muted-2));
    background: color-mix(in srgb, var(--accent-color) 5%, transparent);
    color: var(--accent-color);
  }

  .links-filters {
    display: grid;
    gap: 0.625rem;
  }

  .filter-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 0.75rem 1rem;
    flex-wrap: wrap;
  }

  .filter-pills {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .filter-pill {
    appearance: none;
    transition: background-color var(--transition), color var(--transition), border-color var(--transition), transform var(--transition), box-shadow var(--transition);
    box-shadow: var(--edge-highlight);
    border: 1px solid var(--fg-muted-2);
    border-radius: 999px;
    background: color-mix(in srgb, var(--glass-bg) 82%, transparent);
    padding: 0.5rem 0.875rem;
    color: var(--fg-muted-5);
    font: inherit;
    line-height: 1;
    cursor: pointer;
  }

  .filter-pill.active::before {
    display: inline-block;
    margin-right: 0.35rem;
    border-radius: 50%;
    background: currentColor;
    width: 0.35rem;
    height: 0.35rem;
    vertical-align: 0.05em;
    content: "";
  }

  .filter-pill-count {
    margin-left: 0.35rem;
    color: var(--fg-muted-4);
    font-size: 0.85em;
    font-variant-numeric: tabular-nums;
  }

  .filter-pill.active .filter-pill-count {
    color: currentColor;
  }

  .exchange-link-subtle {
    padding-inline: 0;
  }

  .filter-pill:hover {
    border-color: color-mix(in srgb, var(--accent-color) 36%, var(--fg-muted-2));
    color: var(--fg-color);
  }

  .filter-pill:active {
    transform: var(--active);
  }

  .filter-pill.active {
    border-color: color-mix(in srgb, var(--accent-color) 38%, var(--fg-muted-2));
    background: var(--accent-color-alpha);
    color: var(--accent-color);
  }

  .links-panels {
    display: grid;
    gap: 0;
  }

  :global([data-category-panel][hidden]) {
    display: none !important;
  }

  .links-list {
    display: grid;
    grid-template-columns: 1fr;
    gap: 0.875rem;
  }

  .links-empty {
    box-shadow: var(--edge-highlight), var(--shadow-glass);
    border: 1px solid var(--fg-muted-2);
    border-radius: var(--rounded-corner);
    background: color-mix(in srgb, var(--glass-bg) 84%, transparent);
    margin: 0;
    padding: 1rem 1.125rem;
    color: var(--fg-muted-5);
  }

  .links-apply {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 1rem;
    border-top: 1px solid color-mix(in srgb, var(--accent-color) 20%, var(--fg-muted-2));
    border-radius: 0;
    background: color-mix(in srgb, var(--glass-bg) 58%, transparent);
    padding-top: 1.25rem;
  }

  .links-apply-copy {
    max-width: 34rem;
  }

  .links-apply h2 {
    margin: 0;
    font-family: var(--heading-font-family);
    font-size: 1.1rem;
    line-height: 1.3;
  }

  .links-apply-body {
    margin-top: 0.625rem;
  }

  .links-apply-body p {
    margin: 0.375rem 0 0;
    color: var(--fg-muted-5);
  }

  :global(.friend-card) {
    position: relative;
    display: grid;
    gap: 0.75rem;
    transition: transform var(--transition), border-color var(--transition), background-color var(--transition), box-shadow var(--transition);
    box-shadow: var(--edge-highlight), var(--shadow-glass);
    border: 1px solid var(--fg-muted-2);
    border-radius: var(--rounded-corner);
    background: color-mix(in srgb, var(--glass-bg) 80%, transparent);
    padding: 1rem;
    min-height: 100%;
  }

  :global(.friend-card:hover) {
    transform: translateY(-0.125rem);
    border-color: color-mix(in srgb, var(--accent-color) 40%, var(--fg-muted-2));
    background: color-mix(in srgb, var(--accent-color) 3%, var(--glass-bg));
  }

  :global(.friend-card .card-cover) {
    position: absolute;
    inset: 0;
    border-radius: inherit;
  }

  :global(.friend-card .card-head) {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 0.75rem;
  }

  :global(.friend-card .card-identity) {
    display: flex;
    align-items: flex-start;
    gap: 0.875rem;
    min-width: 0;
  }

  :global(.friend-card .card-avatar) {
    display: grid;
    place-items: center;
    flex: 0 0 auto;
    box-shadow: var(--edge-highlight);
    border: 1px solid var(--fg-muted-2);
    border-radius: 50%;
    background: color-mix(in srgb, var(--accent-color) 8%, var(--glass-bg));
    width: 2.75rem;
    height: 2.75rem;
    object-fit: cover;
  }

  :global(.friend-card .card-avatar-fallback) {
    color: var(--accent-color);
    font-weight: 700;
  }

  :global(.friend-card .card-heading) {
    position: relative;
    z-index: 1;
    min-width: 0;
  }

  :global(.friend-card h3) {
    margin: 0;
    color: var(--fg-color);
    font-size: 1.125rem;
    line-height: 1.2;
    font-family: var(--heading-font-family);
  }

  :global(.friend-card h3 a) {
    transition: color var(--transition);
    color: inherit;
    text-decoration: none;
  }

  :global(.friend-card:hover h3 a) {
    color: var(--accent-color);
  }

  :global(.friend-card .card-site) {
    margin: 0.25rem 0 0;
    color: var(--fg-muted-4);
    font-size: var(--font-size-small);
    word-break: break-all;
  }

  :global(.friend-card .card-arrow) {
    position: relative;
    z-index: 1;
    display: inline-flex;
    justify-content: center;
    align-items: center;
    transition: color var(--transition), background-color var(--transition), transform var(--transition);
    box-shadow: var(--edge-highlight);
    border-radius: 999px;
    background: transparent;
    width: 2rem;
    height: 2rem;
    color: var(--fg-muted-4);
    text-decoration: none;
  }

  :global(.friend-card:hover .card-arrow) {
    color: var(--accent-color);
  }

  :global(.friend-card .card-arrow:hover) {
    transform: translateY(-0.0625rem);
    background: var(--accent-color-alpha);
  }

  :global(.friend-card .card-description) {
    position: relative;
    z-index: 1;
    margin: 0;
    color: var(--fg-muted-5);
  }

  :global(.friend-card .card-footer) {
    position: relative;
    z-index: 1;
    display: grid;
    gap: 0.5rem;
    margin-top: auto;
    padding-top: 0.25rem;
  }

  :global(.friend-card .card-tags) {
    display: flex;
    flex-wrap: wrap;
    gap: 0.375rem;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  :global(.friend-card .card-tags li) {
    box-shadow: var(--edge-highlight);
    border-radius: 999px;
    background: color-mix(in srgb, var(--accent-color) 8%, transparent);
    padding: 0.3125rem 0.625rem;
    color: var(--accent-color);
    font-size: var(--font-size-small);
    line-height: 1;
  }

  @media only screen and (max-width: 760px) {
    .links-hero {
      padding: 1.125rem;
    }

    .links-apply {
      flex-direction: column;
      align-items: flex-start;
    }
  }
</style>
