---
import Graph from "../../graph/Graph.astro";
import {
  friendsGraphUrl,
  friendsGraphVisibleSettingsGroups,
  getFriendsGraphAnchorIds,
  getFriendsGraphCopy,
} from "./config";

interface Props {
  locale: string;
}

const { locale } = Astro.props;
const tagAnchors = getFriendsGraphAnchorIds(locale);
const copy = getFriendsGraphCopy(locale);
---

<section class="friends-graph-panel" data-category-panel="friends" hidden>
  <div class="friends-graph-copy">
    <p>{copy}</p>
  </div>

  <div class="friends-graph-anchors" aria-hidden="true">
    {tagAnchors.map((anchorId) => (
      <span id={anchorId}></span>
    ))}
  </div>

  <Graph
    graphUrl={friendsGraphUrl}
    mode="global"
    locale={locale}
    depth={5}
    settingsEnabled={true}
    controlsMode="toolbar"
    fullscreenEnabled={true}
    height="min(72vh, 42rem)"
    visibleSettingsGroups={friendsGraphVisibleSettingsGroups}
    legendEnabled={false}
  />
</section>

<style>
  .friends-graph-panel {
    display: grid;
    gap: 0.875rem;
  }

  .friends-graph-copy p {
    margin: 0;
    color: var(--fg-muted-5);
  }

  .friends-graph-anchors {
    position: absolute;
    width: 0;
    height: 0;
    overflow: hidden;
  }

  .friends-graph-anchors span {
    display: block;
    width: 0;
    height: 0;
  }
</style>
