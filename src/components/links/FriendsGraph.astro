---
import Graph from "../graph/Graph.astro";
import friendsGraphData from "../../data/friends-graph.json";
import friendsGraphUrl from "../../data/friends-graph.json?url";

interface Props {
  locale: string;
}

const { locale } = Astro.props;

const tagAnchors = friendsGraphData.nodes
  .map((node) => node.urls?.[locale as "en" | "zh-cn"] ?? node.urls?.en)
  .filter((url): url is string => typeof url === "string" && url.includes("#"))
  .map((url) => url.slice(url.indexOf("#") + 1));

const copy = locale === "zh-cn"
  ? "这里的朋友关系单独维护：共享标签会自然聚在一起，少量重要关系则直接落在边上。"
  : "This friend graph is maintained separately: shared tags gather people into small constellations, while important ties live directly on the edges.";
---

<section class="friends-graph-panel" data-category-panel="friends" hidden>
  <div class="friends-graph-copy">
    <p>{copy}</p>
  </div>

  <div class="friends-graph-anchors" aria-hidden="true">
    {tagAnchors.map((anchorId) => (
      <span id={anchorId}></span>
    ))}
  </div>

  <Graph
    graphUrl={friendsGraphUrl}
    mode="global"
    locale={locale}
    depth={5}
    settingsEnabled={true}
    controlsMode="toolbar"
    fullscreenEnabled={true}
    height="min(72vh, 42rem)"
    visibleSettingsGroups={["appearance", "forces", "layout"]}
    legendEnabled={false}
  />
</section>

<style>
  .friends-graph-panel {
    display: grid;
    gap: 0.875rem;
  }

  .friends-graph-copy p {
    margin: 0;
    color: var(--fg-muted-5);
  }

  .friends-graph-anchors {
    position: absolute;
    width: 0;
    height: 0;
    overflow: hidden;
  }

  .friends-graph-anchors span {
    display: block;
    width: 0;
    height: 0;
  }
</style>
