---
interface Props {
  graphUrl?: string;
  focusNodeId?: string;
  mode?: 'local' | 'global';
  height?: string;
  locale?: string;
}

const {
  graphUrl = '/graph.json',
  focusNodeId,
  mode = 'global',
  height = '70vh',
  locale = 'en',
} = Astro.props;
---

<div
  class="graph-root"
  data-graph-root
  data-graph-url={graphUrl}
  data-focus-id={focusNodeId}
  data-mode={mode}
  data-locale={locale}
  style={`height:${height}`}
>
  <div class="graph-empty">Loading graph...</div>
</div>

<style>
  .graph-root {
    position: relative;
    width: 100%;
    min-height: 18rem;
    box-shadow: var(--edge-highlight), var(--shadow);
    border-radius: var(--rounded-corner);
    background-color: var(--fg-muted-1);
    overflow: hidden;
  }

  .graph-root svg {
    display: block;
    width: 100%;
    height: 100%;
    cursor: grab;
    touch-action: none;
  }

  .graph-root svg.is-dragging {
    cursor: grabbing;
  }

  .graph-empty {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    height: 100%;
    color: var(--fg-muted-5);
    font-size: var(--font-size-small);
  }

  .graph-node-label {
    fill: var(--fg-color);
    font-size: 0.75rem;
    pointer-events: none;
  }

  .graph-link-line {
    vector-effect: non-scaling-stroke;
  }

  .graph-node {
    vector-effect: non-scaling-stroke;
  }
</style>

<script type="module">
  import * as d3 from 'https://cdn.jsdelivr.net/npm/d3@7/+esm';

  const COLORS = {
    project_note: '#f97316',
    concept_note: '#8b5cf6',
    blog_post: '#14b8a6',
    default: '#94a3b8',
  };

  const GRAPH_OPTIONS = {
    local: {
      linkDistance: 90,
      chargeStrength: -260,
      collisionRadius: 34,
    },
    global: {
      linkDistance: 110,
      chargeStrength: -220,
      collisionRadius: 28,
    },
  };

  function filterLocalGraph(data, focusId) {
    if (!focusId) {
      return { nodes: [], links: [] };
    }

    const validLinks = data.links.filter((item) => item.exists);
    const neighbors = new Set([focusId]);

    for (const link of validLinks) {
      if (link.source === focusId) {
        neighbors.add(link.target);
      }
      if (link.target === focusId) {
        neighbors.add(link.source);
      }
    }

    return {
      nodes: data.nodes.filter((node) => neighbors.has(node.id)),
      links: validLinks.filter((link) => neighbors.has(link.source) && neighbors.has(link.target)),
    };
  }

  function resolveFocusId(root) {
    const explicit = root.dataset.focusId;
    if (explicit) {
      return explicit;
    }

    const queryFocus = new URLSearchParams(window.location.search).get('focus');
    return queryFocus || undefined;
  }

  function labelForNode(node, locale) {
    return node.titles?.[locale] || node.titles?.['zh-cn'] || node.titles?.['en'] || node.id;
  }

  function buildRenderableGraph(fullData, mode, focusId) {
    if (mode === 'local') {
      return filterLocalGraph(fullData, focusId);
    }

    return {
      nodes: fullData.nodes,
      links: fullData.links.filter((item) => item.exists),
    };
  }

  function createSvg(root, width, height) {
    const svg = d3.create('svg').attr('viewBox', `0 0 ${width} ${height}`);
    const canvas = svg.append('g').attr('data-graph-canvas', '');

    const zoom = d3
      .zoom()
      .scaleExtent([0.4, 3])
      .on('start', () => {
        svg.classed('is-dragging', true);
      })
      .on('zoom', (event) => {
        canvas.attr('transform', event.transform);
      })
      .on('end', () => {
        svg.classed('is-dragging', false);
      });

    svg.call(zoom);
    svg.call(
      zoom.transform,
      d3.zoomIdentity.translate(width * 0.12, height * 0.08).scale(1),
    );

    return { svg, canvas };
  }

  function createSimulation(nodes, links, mode, width, height) {
    const options = GRAPH_OPTIONS[mode] ?? GRAPH_OPTIONS.global;

    return d3
      .forceSimulation(nodes)
      .force('link', d3.forceLink(links).id((d) => d.id).distance(options.linkDistance))
      .force('charge', d3.forceManyBody().strength(options.chargeStrength))
      .force('center', d3.forceCenter(width / 2, height / 2))
      .force('collision', d3.forceCollide().radius(options.collisionRadius));
  }

  function renderGraph(canvas, data, locale, focusId) {
    const link = canvas
      .append('g')
      .attr('stroke', '#64748b')
      .attr('stroke-opacity', 0.35)
      .selectAll('line')
      .data(data.links)
      .join('line')
      .attr('class', 'graph-link-line')
      .attr('stroke-width', 1.25);

    const node = canvas
      .append('g')
      .selectAll('circle')
      .data(data.nodes)
      .join('circle')
      .attr('class', 'graph-node')
      .attr('r', (d) => (d.id === focusId ? 9 : 6))
      .attr('fill', (d) => COLORS[d.type] ?? COLORS.default)
      .attr('stroke', (d) => (d.id === focusId ? 'var(--accent-color)' : 'transparent'))
      .attr('stroke-width', (d) => (d.id === focusId ? 2 : 0))
      .style('cursor', 'pointer')
      .on('click', (_, d) => {
        const targetUrl = d.urls?.[locale] || d.urls?.['zh-cn'] || d.urls?.['en'];
        if (targetUrl) {
          window.location.href = targetUrl;
        }
      });

    const label = canvas
      .append('g')
      .selectAll('text')
      .data(data.nodes)
      .join('text')
      .text((d) => labelForNode(d, locale))
      .attr('class', 'graph-node-label')
      .attr('dx', 10)
      .attr('dy', 4);

    return { link, node, label };
  }

  async function initGraph(root) {
    const graphUrl = root.dataset.graphUrl || '/graph.json';
    const mode = root.dataset.mode || 'global';
    const locale = root.dataset.locale || 'en';
    const focusId = resolveFocusId(root);
    const empty = root.querySelector('.graph-empty');

    try {
      const response = await fetch(graphUrl);
      const fullData = await response.json();
      const data = buildRenderableGraph(fullData, mode, focusId);

      if (!data.nodes.length) {
        if (empty) {
          empty.textContent = mode === 'local' ? 'No related graph data yet.' : 'No graph data available.';
        }
        return;
      }

      const rect = root.getBoundingClientRect();
      const width = Math.max(rect.width, 320);
      const height = Math.max(rect.height, 288);

      const { svg, canvas } = createSvg(root, width, height);
      const simulation = createSimulation(data.nodes, data.links, mode, width, height);
      const { link, node, label } = renderGraph(canvas, data, locale, focusId);

      simulation.on('tick', () => {
        link
          .attr('x1', (d) => d.source.x ?? 0)
          .attr('y1', (d) => d.source.y ?? 0)
          .attr('x2', (d) => d.target.x ?? 0)
          .attr('y2', (d) => d.target.y ?? 0);

        node.attr('cx', (d) => d.x ?? 0).attr('cy', (d) => d.y ?? 0);
        label.attr('x', (d) => d.x ?? 0).attr('y', (d) => d.y ?? 0);
      });

      root.replaceChildren(svg.node());
    } catch (error) {
      console.error('Graph render failed', error);
      if (empty) {
        empty.textContent = 'Failed to load graph data.';
      }
    }
  }

  const roots = document.querySelectorAll('[data-graph-root]');
  roots.forEach((root) => {
    initGraph(root);
  });
</script>
