---
import { DEFAULT_DEPTH, DEFAULT_LAYOUT, resolveGraphSettings } from '../../graph/constants';
import I18nKey from '../../i18n/i18nKey';
import { useTranslations } from '../../i18n/translation';
import graphClientUrl from './graph-client.ts?url';

interface Props {
  graphUrl?: string;
  focusNodeId?: string;
  mode?: 'local' | 'global';
  height?: string;
  locale?: string;
  depth?: number;
  layout?: 'force' | 'brain' | 'radial' | 'hierarchy';
  physics?: Record<string, number>;
  render?: Record<string, number>;
  navigationSearch?: string;
  settingsEnabled?: boolean;
  controlsMode?: 'overlay' | 'toolbar';
  fullscreenEnabled?: boolean;
}

const {
  graphUrl = '/graph.json',
  focusNodeId,
  mode = 'global',
  height = '70vh',
  locale = 'en',
  depth = DEFAULT_DEPTH,
  layout = DEFAULT_LAYOUT,
  physics,
  render,
  navigationSearch,
  settingsEnabled = false,
  controlsMode = 'overlay',
  fullscreenEnabled = false,
} = Astro.props;

const t = useTranslations(locale);
const toolbarSearchPlaceholder = t(I18nKey.graph_toolbar_search_placeholder);
const enterFullscreenLabel = t(I18nKey.graph_enter_fullscreen);
const exitFullscreenLabel = t(I18nKey.graph_exit_fullscreen);
const legendLabel = t(I18nKey.graph_legend);
const legendFiltersLabel = t(I18nKey.graph_legend_filters);
const nodeDetailsLabel = t(I18nKey.graph_node_details);
const openArticleLabel = t(I18nKey.graph_open_article);
const focusRelatedLabel = t(I18nKey.graph_focus_related);
const selectNodeHint = t(I18nKey.graph_select_node_hint);
const nodeTypeLabel = t(I18nKey.graph_type);
const tagsLabel = t(I18nKey.tags);
const createdLabel = t(I18nKey.created);
const updatedLabel = t(I18nKey.updated);
const initialSettings = resolveGraphSettings(mode, layout, {
  filters: {
    depth,
  },
  appearance: {
    nodeRadius: render?.nodeBaseRadius,
    focusNodeRadius: render?.nodeFocusRadius,
    linkWidth: render?.linkBaseWidth,
  },
  forces: {
    centerStrength: physics?.centerStrength,
    repelStrength: typeof physics?.chargeStrength === 'number' ? Math.abs(physics.chargeStrength) : undefined,
    linkDistance: physics?.linkDistance,
    collisionPadding: physics?.collisionRadius,
  },
  layout: {
    preset: layout,
  },
});
---

<div
  class="graph-shell"
  data-graph-shell
  data-graph-controls-mode={controlsMode}
  data-graph-delete-color-group-label={t(I18nKey.graph_delete_color_group)}
  data-graph-enter-fullscreen-label={enterFullscreenLabel}
  data-graph-exit-fullscreen-label={exitFullscreenLabel}
  data-graph-legend-label={legendLabel}
  data-graph-node-details-label={nodeDetailsLabel}
  data-graph-open-article-label={openArticleLabel}
  data-graph-focus-related-label={focusRelatedLabel}
  data-graph-select-node-hint={selectNodeHint}
  data-graph-type-label={nodeTypeLabel}
  data-graph-tags-label={tagsLabel}
  data-graph-created-label={createdLabel}
  data-graph-updated-label={updatedLabel}
>
  {controlsMode === 'toolbar' && (
    <div class="graph-toolbar" data-graph-toolbar>
      <label class="graph-toolbar-search" data-graph-setting-field="searchQuery">
        <input
          type="search"
          data-graph-setting-input="searchQuery"
          placeholder={toolbarSearchPlaceholder}
          aria-label={t(I18nKey.graph_search)}
        />
      </label>

      <button type="button" class="graph-toolbar-button" data-graph-toolbar-reset>
        {t(I18nKey.graph_reset_view)}
      </button>

      <div class="graph-toolbar-spacer" aria-hidden="true"></div>

      {fullscreenEnabled && (
        <button
          type="button"
          class="graph-toolbar-icon-button"
          data-graph-toolbar-fullscreen
          aria-label={enterFullscreenLabel}
          title={enterFullscreenLabel}
        >
          <span aria-hidden="true">⛶</span>
        </button>
      )}
    </div>
  )}

  {settingsEnabled && (
    <div class="graph-settings" data-graph-settings>
      <button
        class="graph-settings-toggle"
        type="button"
        data-graph-settings-toggle
        aria-label={t(I18nKey.graph_settings)}
        title={t(I18nKey.graph_settings)}
      >
        <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false">
          <path d="M19.14 12.94a7.43 7.43 0 0 0 .05-.94 7.43 7.43 0 0 0-.05-.94l2.03-1.58a.5.5 0 0 0 .12-.64l-1.92-3.32a.5.5 0 0 0-.6-.22l-2.39.96a7.2 7.2 0 0 0-1.63-.94l-.36-2.54A.5.5 0 0 0 13.9 2h-3.8a.5.5 0 0 0-.49.42l-.36 2.54a7.2 7.2 0 0 0-1.63.94l-2.39-.96a.5.5 0 0 0-.6.22L2.71 8.48a.5.5 0 0 0 .12.64l2.03 1.58a7.43 7.43 0 0 0-.05.94c0 .32.02.63.05.94l-2.03 1.58a.5.5 0 0 0-.12.64l1.92 3.32a.5.5 0 0 0 .6.22l2.39-.96c.5.39 1.05.7 1.63.94l.36 2.54a.5.5 0 0 0 .49.42h3.8a.5.5 0 0 0 .49-.42l.36-2.54c.58-.24 1.13-.55 1.63-.94l2.39.96a.5.5 0 0 0 .6-.22l1.92-3.32a.5.5 0 0 0-.12-.64zM12 15.2A3.2 3.2 0 1 1 12 8.8a3.2 3.2 0 0 1 0 6.4z" fill="currentColor"></path>
        </svg>
      </button>

      <aside class="graph-settings-panel" data-graph-settings-panel aria-hidden="true">
        <div class="graph-settings-header">
          <strong>{t(I18nKey.graph_settings)}</strong>
          <button type="button" class="graph-settings-reset" data-graph-settings-reset>{t(I18nKey.graph_reset)}</button>
        </div>

        <section class="graph-settings-group" data-graph-settings-group>
          <button class="graph-settings-group-toggle" type="button" data-graph-section-toggle aria-expanded="false">
            <span class="graph-settings-chevron" aria-hidden="true"></span>
            <span>{t(I18nKey.graph_templates)}</span>
          </button>
          <div class="graph-settings-group-content is-collapsed" data-graph-section-content>
            <label class="graph-settings-field">
              <span>{t(I18nKey.graph_template)}</span>
              <select data-graph-preset-select></select>
            </label>
            <div class="graph-settings-actions-row">
              <button type="button" class="graph-settings-action" data-graph-preset-save>{t(I18nKey.graph_save_preset)}</button>
              <button type="button" class="graph-settings-action" data-graph-preset-reset>{t(I18nKey.graph_reset_preset)}</button>
            </div>
            <div class="graph-settings-actions-row" data-graph-debug-only hidden>
              <button type="button" class="graph-settings-action" data-graph-preset-overwrite>{t(I18nKey.graph_overwrite_preset)}</button>
              <button type="button" class="graph-settings-action" data-graph-preset-export>{t(I18nKey.graph_export_preset)}</button>
              <button type="button" class="graph-settings-action" data-graph-preset-import>{t(I18nKey.graph_import_preset)}</button>
            </div>
          </div>
        </section>

        <section class="graph-settings-group" data-graph-settings-group>
          <button class="graph-settings-group-toggle" type="button" data-graph-section-toggle aria-expanded="false">
            <span class="graph-settings-chevron" aria-hidden="true"></span>
            <span>{t(I18nKey.graph_filters)}</span>
          </button>
          <div class="graph-settings-group-content is-collapsed" data-graph-section-content>
            <label class="graph-settings-field" data-graph-setting-field="searchQuery">
              <span>{t(I18nKey.graph_search)}</span>
              <input type="search" data-graph-setting-input="searchQuery" placeholder={t(I18nKey.graph_search_placeholder)} />
            </label>

            <label class="graph-settings-field" data-graph-setting-field="depth">
              <span>{t(I18nKey.graph_depth)}</span>
              <div class="graph-settings-range-row">
                <input type="range" min="1" max="5" step="1" data-graph-setting-input="depth" />
                <output data-graph-setting-value="depth"></output>
              </div>
            </label>

            <label class="graph-settings-toggle-row" data-graph-setting-field="showBacklinks">
              <span>{t(I18nKey.graph_show_backlinks)}</span>
              <input type="checkbox" class="graph-switch" data-graph-setting-input="showBacklinks" />
            </label>
            <label class="graph-settings-toggle-row" data-graph-setting-field="showForwardLinks">
              <span>{t(I18nKey.graph_show_forward_links)}</span>
              <input type="checkbox" class="graph-switch" data-graph-setting-input="showForwardLinks" />
            </label>
            <label class="graph-settings-toggle-row" data-graph-setting-field="showCrossLinks">
              <span>{t(I18nKey.graph_show_cross_links)}</span>
              <input type="checkbox" class="graph-switch" data-graph-setting-input="showCrossLinks" />
            </label>
            <label class="graph-settings-toggle-row" data-graph-setting-field="showTags">
              <span>{t(I18nKey.graph_show_tags)}</span>
              <input type="checkbox" class="graph-switch" data-graph-setting-input="showTags" />
            </label>
            <label class="graph-settings-toggle-row" data-graph-setting-field="showAttachments">
              <span>{t(I18nKey.graph_show_attachments)}</span>
              <input type="checkbox" class="graph-switch" data-graph-setting-input="showAttachments" />
            </label>
            <label class="graph-settings-toggle-row" data-graph-setting-field="onlyExistingNotes">
              <span>{t(I18nKey.graph_only_existing_notes)}</span>
              <input type="checkbox" class="graph-switch" data-graph-setting-input="onlyExistingNotes" />
            </label>
          </div>
        </section>

        <section class="graph-settings-group" data-graph-settings-group>
          <button class="graph-settings-group-toggle" type="button" data-graph-section-toggle aria-expanded="false">
            <span class="graph-settings-chevron" aria-hidden="true"></span>
            <span>{t(I18nKey.graph_appearance)}</span>
          </button>
          <div class="graph-settings-group-content is-collapsed" data-graph-section-content>
            <label class="graph-settings-toggle-row" data-graph-setting-field="showArrows">
              <span>{t(I18nKey.graph_show_arrows)}</span>
              <input type="checkbox" class="graph-switch" data-graph-setting-input="showArrows" />
            </label>

            <label class="graph-settings-field" data-graph-setting-field="textOpacity">
              <span>{t(I18nKey.graph_text_opacity)}</span>
              <div class="graph-settings-range-row">
                <input type="range" min="0" max="1" step="0.05" data-graph-setting-input="textOpacity" />
                <output data-graph-setting-value="textOpacity"></output>
              </div>
            </label>
            <label class="graph-settings-field" data-graph-setting-field="nodeRadius">
              <span>{t(I18nKey.graph_node_radius)}</span>
              <div class="graph-settings-range-row">
                <input type="range" min="2" max="20" step="1" data-graph-setting-input="nodeRadius" />
                <output data-graph-setting-value="nodeRadius"></output>
              </div>
            </label>
            <label class="graph-settings-field" data-graph-setting-field="linkWidth">
              <span>{t(I18nKey.graph_link_width)}</span>
              <div class="graph-settings-range-row">
                <input type="range" min="0.5" max="6" step="0.25" data-graph-setting-input="linkWidth" />
                <output data-graph-setting-value="linkWidth"></output>
              </div>
            </label>
            <label class="graph-settings-field" data-graph-setting-field="labelSize">
              <span>{t(I18nKey.graph_label_size)}</span>
              <div class="graph-settings-range-row">
                <input type="range" min="8" max="20" step="1" data-graph-setting-input="labelSize" />
                <output data-graph-setting-value="labelSize"></output>
              </div>
            </label>
          </div>
        </section>

        <section class="graph-settings-group" data-graph-settings-group>
          <button class="graph-settings-group-toggle" type="button" data-graph-section-toggle aria-expanded="false">
            <span class="graph-settings-chevron" aria-hidden="true"></span>
            <span>{t(I18nKey.graph_color_groups)}</span>
          </button>
          <div class="graph-settings-group-content is-collapsed" data-graph-section-content>
            <div class="graph-color-groups" data-graph-color-groups></div>
            <div class="graph-settings-actions-row">
              <button type="button" class="graph-settings-action" data-graph-color-group-add>{t(I18nKey.graph_add_color_group)}</button>
              <button type="button" class="graph-settings-action" data-graph-color-group-reset>{t(I18nKey.graph_reset_color_groups)}</button>
            </div>
          </div>
        </section>

        <section class="graph-settings-group" data-graph-settings-group data-graph-debug-only hidden>
          <button class="graph-settings-group-toggle" type="button" data-graph-section-toggle aria-expanded="false">
            <span class="graph-settings-chevron" aria-hidden="true"></span>
            <span>{t(I18nKey.graph_advanced_forces)}</span>
          </button>
          <div class="graph-settings-group-content is-collapsed" data-graph-section-content>
            <label class="graph-settings-field" data-graph-setting-field="collisionStrength">
              <span>{t(I18nKey.graph_collision_strength)}</span>
              <div class="graph-settings-range-row">
                <input type="range" min="0" max="1" step="0.01" data-graph-setting-input="collisionStrength" />
                <output data-graph-setting-value="collisionStrength"></output>
              </div>
            </label>
            <label class="graph-settings-field" data-graph-setting-field="localGravityStrength" title="将当前焦点节点轻微拉回图谱中心，不会永久固定节点。">
              <span>{t(I18nKey.graph_focus_gravity_strength)}</span>
              <div class="graph-settings-range-row">
                <input type="range" min="0" max="0.4" step="0.01" data-graph-setting-input="localGravityStrength" />
                <output data-graph-setting-value="localGravityStrength"></output>
              </div>
            </label>
            <label class="graph-settings-field" data-graph-setting-field="collisionPadding">
              <span>{t(I18nKey.graph_collision_padding)}</span>
              <div class="graph-settings-range-row">
                <input type="range" min="0" max="32" step="1" data-graph-setting-input="collisionPadding" />
                <output data-graph-setting-value="collisionPadding"></output>
              </div>
            </label>
            <label class="graph-settings-field" data-graph-setting-field="velocityDecay">
              <span>{t(I18nKey.graph_velocity_decay)}</span>
              <div class="graph-settings-range-row">
                <input type="range" min="0.15" max="0.75" step="0.01" data-graph-setting-input="velocityDecay" />
                <output data-graph-setting-value="velocityDecay"></output>
              </div>
            </label>
            <label class="graph-settings-field" data-graph-setting-field="alphaDecay">
              <span>{t(I18nKey.graph_alpha_decay)}</span>
              <div class="graph-settings-range-row">
                <input type="range" min="0.005" max="0.08" step="0.001" data-graph-setting-input="alphaDecay" />
                <output data-graph-setting-value="alphaDecay"></output>
              </div>
            </label>
          </div>
        </section>

        <section class="graph-settings-group" data-graph-settings-group>
          <button class="graph-settings-group-toggle" type="button" data-graph-section-toggle aria-expanded="false">
            <span class="graph-settings-chevron" aria-hidden="true"></span>
            <span>{t(I18nKey.graph_forces)}</span>
          </button>
          <div class="graph-settings-group-content is-collapsed" data-graph-section-content>
            <label class="graph-settings-field" data-graph-setting-field="centerStrength">
              <span>{t(I18nKey.graph_center_strength)}</span>
              <div class="graph-settings-range-row">
                <input type="range" min="0" max="1" step="0.01" data-graph-setting-input="centerStrength" />
                <output data-graph-setting-value="centerStrength"></output>
              </div>
            </label>
            <label class="graph-settings-field" data-graph-setting-field="repelStrength">
              <span>{t(I18nKey.graph_repel_strength)}</span>
              <div class="graph-settings-range-row">
                <input type="range" min="0" max="100" step="1" data-graph-setting-input="repelStrength" />
                <output data-graph-setting-value="repelStrength"></output>
              </div>
            </label>
            <label class="graph-settings-field" data-graph-setting-field="linkStrength">
              <span>{t(I18nKey.graph_link_strength)}</span>
              <div class="graph-settings-range-row">
                <input type="range" min="0" max="1" step="0.01" data-graph-setting-input="linkStrength" />
                <output data-graph-setting-value="linkStrength"></output>
              </div>
            </label>
            <label class="graph-settings-field" data-graph-setting-field="linkDistance">
              <span>{t(I18nKey.graph_link_distance)}</span>
              <div class="graph-settings-range-row">
                <input type="range" min="30" max="320" step="5" data-graph-setting-input="linkDistance" />
                <output data-graph-setting-value="linkDistance"></output>
              </div>
            </label>
          </div>
        </section>

        <section class="graph-settings-group" data-graph-settings-group>
          <button class="graph-settings-group-toggle" type="button" data-graph-section-toggle aria-expanded="false">
            <span class="graph-settings-chevron" aria-hidden="true"></span>
            <span>{t(I18nKey.graph_layout_section)}</span>
          </button>
          <div class="graph-settings-group-content is-collapsed" data-graph-section-content>
            <label class="graph-settings-field" data-graph-setting-field="preset">
              <span>{t(I18nKey.graph_layout)}</span>
              <select data-graph-setting-input="preset">
                <option value="force">{t(I18nKey.graph_layout_default)}</option>
                <option value="brain">{t(I18nKey.graph_layout_brain)}</option>
                <option value="radial">{t(I18nKey.graph_layout_radial)}</option>
                <option value="hierarchy">{t(I18nKey.graph_layout_hierarchy)}</option>
              </select>
            </label>
            <label class="graph-settings-field" data-graph-setting-field="brainAnchorStrength">
              <span>{t(I18nKey.graph_brain_anchor_strength)}</span>
              <div class="graph-settings-range-row">
                <input type="range" min="0" max="1" step="0.01" data-graph-setting-input="brainAnchorStrength" />
                <output data-graph-setting-value="brainAnchorStrength"></output>
              </div>
            </label>
            <label class="graph-settings-toggle-row" data-graph-setting-field="preserveSelectedPreset">
              <span>{t(I18nKey.graph_preserve_selected_preset)}</span>
              <input type="checkbox" class="graph-switch" data-graph-setting-input="preserveSelectedPreset" />
            </label>
          </div>
        </section>
      </aside>
    </div>
  )}

  <div class="graph-workspace">
    {mode === 'global' && controlsMode === 'toolbar' && (
      <>
        <button type="button" class="graph-side-toggle graph-toolbar-button" data-graph-legend-toggle aria-expanded="false">
          {legendFiltersLabel}
        </button>

        <aside class="graph-legend-panel" data-graph-legend-panel aria-hidden="true">
          <div class="graph-side-panel-header">
            <strong>{legendLabel}</strong>
          </div>
          <div class="graph-legend-items" data-graph-legend-items></div>

          <div class="graph-side-panel-divider"></div>

          <div class="graph-side-panel-header graph-side-panel-header-secondary">
            <strong>{t(I18nKey.graph_filters)}</strong>
          </div>
          <div class="graph-side-filter-list">
            <label class="graph-settings-toggle-row" data-graph-setting-field="showTags">
              <span>{t(I18nKey.graph_show_tags)}</span>
              <input type="checkbox" class="graph-switch" data-graph-setting-input="showTags" />
            </label>
            <label class="graph-settings-toggle-row" data-graph-setting-field="showAttachments">
              <span>{t(I18nKey.graph_show_attachments)}</span>
              <input type="checkbox" class="graph-switch" data-graph-setting-input="showAttachments" />
            </label>
            <label class="graph-settings-toggle-row" data-graph-setting-field="onlyExistingNotes">
              <span>{t(I18nKey.graph_only_existing_notes)}</span>
              <input type="checkbox" class="graph-switch" data-graph-setting-input="onlyExistingNotes" />
            </label>
          </div>
        </aside>
      </>
    )}

    <div
      class="graph-root"
      data-graph-root
      data-graph-url={graphUrl}
      data-focus-id={focusNodeId}
      data-mode={mode}
      data-locale={locale}
      data-graph-settings={JSON.stringify(initialSettings)}
      data-navigation-search={navigationSearch}
      style={`height:${height}`}
    >
      <div class="graph-empty">Loading graph...</div>
    </div>

    {mode === 'global' && controlsMode === 'toolbar' && (
      <aside class="graph-detail-drawer" data-graph-detail-drawer aria-hidden="true">
        <div class="graph-side-panel-header">
          <strong>{nodeDetailsLabel}</strong>
          <button type="button" class="graph-side-close graph-toolbar-icon-button" data-graph-detail-close aria-label={t(I18nKey.graph_close)} title={t(I18nKey.graph_close)}>
            <span aria-hidden="true">×</span>
          </button>
        </div>
        <div class="graph-detail-content" data-graph-detail-content></div>
      </aside>
    )}
  </div>
</div>

<style>
  .graph-shell {
    position: relative;
    gap: 0.85rem;
    --graph-panel-bg: color-mix(in srgb, var(--glass-bg) 94%, transparent);
    --graph-panel-border: color-mix(in srgb, var(--fg-muted-3) 32%, transparent);
    --graph-panel-text: var(--fg-color);
    --graph-accent: var(--accent-color);
    --graph-muted: color-mix(in srgb, var(--fg-muted-5) 86%, transparent);
    --graph-node-default: color-mix(in srgb, var(--accent-color) 58%, var(--fg-muted-5));
    --graph-node-hover: color-mix(in srgb, var(--accent-color) 92%, white 8%);
    --graph-node-selected: var(--accent-color);
    --graph-node-stroke: color-mix(in srgb, var(--accent-color) 52%, var(--fg-color));
    --graph-link-default: color-mix(in srgb, var(--fg-muted-5) 86%, transparent);
    --graph-link-highlight: color-mix(in srgb, var(--accent-color) 82%, white 12%);
    --graph-dim-opacity: 0.18;
  }

  .graph-root {
    position: relative;
    width: 100%;
    min-height: 18rem;
    box-shadow: var(--edge-highlight), var(--shadow);
    border-radius: var(--rounded-corner);
    background-color: var(--fg-muted-1);
    overflow: hidden;
  }

  .graph-workspace {
    position: relative;
  }

  .graph-toolbar {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    min-width: 0;
  }

  .graph-toolbar-search {
    flex: 0 1 20rem;
    min-width: min(100%, 14rem);
  }

  .graph-toolbar-search input {
    width: 100%;
    border: 1px solid var(--graph-panel-border);
    border-radius: 999px;
    background: color-mix(in srgb, var(--bg-color) 90%, transparent);
    padding: 0.75rem 1rem;
    color: var(--graph-panel-text);
    font: inherit;
    transition: border-color 180ms ease-out, box-shadow 180ms ease-out, background 180ms ease-out;
  }

  .graph-toolbar-search input:focus {
    outline: none;
    border-color: color-mix(in srgb, var(--graph-accent) 40%, var(--graph-panel-border));
    box-shadow: 0 0 0 3px color-mix(in srgb, var(--graph-accent) 14%, transparent);
  }

  .graph-toolbar-button,
  .graph-toolbar-icon-button {
    appearance: none;
    border: 1px solid var(--graph-panel-border);
    border-radius: 999px;
    background: color-mix(in srgb, var(--bg-color) 90%, transparent);
    color: var(--graph-panel-text);
    font: inherit;
    cursor: pointer;
    transition: background 180ms ease-out, border-color 180ms ease-out, transform 160ms ease-out;
  }

  .graph-toolbar-button {
