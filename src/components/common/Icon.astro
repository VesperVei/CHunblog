---
interface Props {
  name: string;
  set?: 'phosphor' | 'simple' | 'selecticons';
  source?: 'phosphor' | 'simple' | 'selecticons';
  label?: string;
  class?: string;
  size?: string;
}

const {
  name,
  set,
  source,
  label,
  class: className,
  size,
} = Astro.props;

const iconSet = source ?? set ?? 'phosphor';
const iconBase = iconSet === 'selecticons' ? 'selecticons' : `icons/${iconSet}`;

const style = [
  `--icon-url: url('/${iconBase}/${name}.svg')`,
  size ? `--icon-size: ${size}` : undefined,
].filter(Boolean).join('; ');
---

<i
  class:list={['icon', className]}
  style={style}
  aria-hidden={label ? undefined : 'true'}
  aria-label={label}
  role={label ? 'img' : undefined}
/>
