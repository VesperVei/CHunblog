---
import { detectLocale } from "../../utils/i18n";

interface Props {
  date: Date;
  text?: string;
}

const { date, text } = Astro.props;
const currentLocale = detectLocale(Astro.url.pathname);
---

<time datetime={date.toISOString()}>
  {text}
  {
    date.toLocaleDateString(currentLocale, {
      year: 'numeric',
      month: 'short',
      day: 'numeric',
    })
  }
</time>
