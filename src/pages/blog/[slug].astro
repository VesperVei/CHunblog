---
import BlogPost from '../../layouts/BlogPost.astro';
import ExtendMarkdown from '../../components/markdown/ExtendMarkdown.astro';
import { render } from 'astro:content';
import { getBlogPostStaticPaths, isMultiLangMode } from '../../utils/pages';

if (isMultiLangMode()) {
  return Astro.redirect('/404');
}

export async function getStaticPaths() {
  return getBlogPostStaticPaths();
}

const { post, prevPost, nextPost } = Astro.props;
const { headings } = await render(post);
---

<BlogPost
  post={post}
  headings={headings}
  prev={prevPost}
  next={nextPost}
>
  <ExtendMarkdown page={post} />
</BlogPost>
