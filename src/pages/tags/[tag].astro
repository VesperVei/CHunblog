---
import Base from '../../layouts/Base.astro';
import BlogCard from '../../components/blog/BlogCard.astro';
import { getTagStaticPaths, getPostByTag, isMultiLangMode } from '../../utils/pages';

if (isMultiLangMode()) {
  return Astro.redirect('/404');
}

export async function getStaticPaths() {
  return getTagStaticPaths();
}

const { tag } = Astro.params;
const decodedTag = tag ? decodeURIComponent(tag) : '';
const posts = await getPostByTag(decodedTag);
const title = `#${decodedTag}`;
const description = `${posts.length} posts tagged with ${decodedTag}`;
---

<Base title={title} description={description}>
  <h1>#{decodedTag}</h1>
  <BlogCard posts={posts} />
</Base>
