---
import Tags from '../../components/blog/Tags.astro';
import ExtendMarkdown from '../../components/markdown/ExtendMarkdown.astro';
import { getRenderedPageBySlug, isMultiLangMode } from '../../utils/pages';

if (isMultiLangMode()) {
  return Astro.redirect('/404');
}

const pageData = await getRenderedPageBySlug('tags');
const { lang, page: contentPage, title: pageTitle, description: pageDescription } = pageData ?? {};
---

<Tags lang={lang} pageTitle={pageTitle} pageDescription={pageDescription}>
  {contentPage ? <ExtendMarkdown page={contentPage} /> : null}
</Tags>
