---
import BlogList from '../../../components/blog/BlogList.astro';
import ExtendMarkdown from '../../../components/markdown/ExtendMarkdown.astro';
import { getBlogListPage, getLocalizedBlogPaginationPaths, isMultiLangMode } from '../../../utils/pages';

const { lang } = Astro.params;

if (!isMultiLangMode()) {
  return Astro.redirect('/404');
}

const pageData = await getBlogListPage(lang);
const { page: contentPage, title, description } = pageData ?? {};

export async function getStaticPaths({ paginate }) {
  return getLocalizedBlogPaginationPaths(paginate);
}

const { page: paginatedPage } = Astro.props;
---

<BlogList title={title} description={description} page={paginatedPage}>
  {contentPage ? <ExtendMarkdown page={contentPage} /> : null}
</BlogList>
