---
import GraphPage from '../../components/graph/GraphPage.astro';
import { getLocalizedStaticPaths, isMultiLangMode } from '../../utils/pages';

export function getStaticPaths() {
  return getLocalizedStaticPaths();
}

const { lang } = Astro.params;

if (!isMultiLangMode()) {
  return Astro.redirect('/404');
}

const currentLocale = lang || 'en';
---

<GraphPage locale={currentLocale} />
