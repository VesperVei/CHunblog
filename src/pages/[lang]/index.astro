---
import Base from '../../layouts/Base.astro';
import ExtendMarkdown from '../../components/markdown/ExtendMarkdown.astro';
import { getLocalizedStaticPaths, getRenderedPageBySlug, isMultiLangMode } from '../../utils/pages';

export function getStaticPaths() {
  return getLocalizedStaticPaths();
}

const { lang } = Astro.params;
if (!isMultiLangMode()) {
  return Astro.redirect('/404');
}

const pageData = await getRenderedPageBySlug('index', lang);

if (!pageData) {
  return Astro.redirect('/404');
}

const { page: contentPage, title, description } = pageData;
---

<Base title={title} description={description}>
  <ExtendMarkdown page={contentPage} />
</Base>
