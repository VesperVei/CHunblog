---
import Base from './Base.astro';
import type { CollectionEntry } from 'astro:content';
import BlogPostHeader from '../components/blog/BlogPostHeader.astro';
import BlogPostHero from '../components/blog/BlogPostHero.astro';
import BlogPostInlineToc from '../components/blog/BlogPostInlineToc.astro';
import BlogPostNav from '../components/blog/BlogPostNav.astro';
import BlogPostTocControls from '../components/blog/BlogPostTocControls.astro';
import Comments from '../components/blog/Comments.astro';
import Statements from '../components/blog/Statements.astro';

type ArticleEntry = CollectionEntry<'blog'> | CollectionEntry<'pages'>;

interface Props {
  post: ArticleEntry;
  headings?: { depth: number; slug: string; text: string }[];
  prev?: CollectionEntry<'blog'> | null;
  next?: CollectionEntry<'blog'> | null;
}

const { post, headings, prev, next } = Astro.props as Props;
const data = post.data;
const words = (post.body || '').split(/\s+/).filter(w => w).length;
const minutes = Math.ceil(words / 200);
const title = data.title;
const description = data.description;
const comment = data.comment;
---

<Base title={title} description={description}>
  <article>
    <BlogPostHero data={data} />
    <BlogPostHeader data={data} words={words} minutes={minutes} />
    <Statements data={data} />
    {headings && (
      <>
        <BlogPostTocControls headings={headings} showToc={data.toc} tocDepth={data.toc_depth} />
        <BlogPostInlineToc headings={headings} showToc={data.toc_inline} tocDepth={data.toc_depth} />
      </>
    )}
    <slot />
  </article>

  {comment && <Comments /> }

  <hr />
  <BlogPostNav prev={prev} next={next} />
</Base>
